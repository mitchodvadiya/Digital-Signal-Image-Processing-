# signal 1
import numpy as np
import matplotlib.pyplot as plt

n = np.arange(-3,7)
x = np.where(n % 2 == 0, 3, 2)

plt.stem(n, x)
plt.grid(True)
plt.xlabel("n")
plt.ylabel("x[n]")
plt.title("Signal 1")
plt.show()

# signal 2
import matplotlib.pyplot as plt

n = [0,1,2,3,4,5,6]
x = [1,2,3,3,2,1,0]

plt.step(n, x, where='post')
plt.scatter(n,x)
plt.grid(True)
plt.xlabel("n")
plt.ylabel("x[n]")
plt.title("Signal 2")
plt.show()

